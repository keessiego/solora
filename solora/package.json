{
  "name": "@kerkhoff-ict/solora",
  "version": "2.1.9",
  "description": "Simple CSS component library",
  "main": "dist/index.js",
  "style": "dist/index.css",
  "files": [
    "dist"
  ],
  "scripts": {
    "build:css": "mkdir -p dist && postcss src/index.css -o dist/index.css",
    "build:js": "mkdir -p dist && esbuild src/index.js --bundle --outfile=dist/index.js --format=esm",
    "build": "npm run build:css && npm run build:js",
    "watch:css": "mkdir -p dist && postcss src/index.css -o dist/index.css --watch"
  },
  "author": "Kerkhoff-ICT",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.27.4",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1"
  },
  "dependencies": {
    "prismjs": "^1.30.0"
  }
}
